# Copy to .env.local and fill in. See docs/SETUP-GO-LIVE.md for where each value comes from.
# On Vercel, set the same keys under Project -> Settings -> Environment Variables.

# --- Application ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
NEXT_PUBLIC_MAIN_SITE_URL=https://suncontainer.de
APP_DEFAULT_LOCALE=de
DEMO_MODE=false
TRACKING_LINK_SECRET=        # openssl rand -hex 32
CRON_SECRET=                 # openssl rand -hex 32

# --- Supabase (auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # anon public key
SUPABASE_SECRET_KEY=                    # service_role key (keep secret)

# --- PostgreSQL (Supabase) ---
# Pooled (port 6543) for the running app:
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-...pooler.supabase.com:6543/postgres?sslmode=require
# Direct (port 5432) for migrations:
DATABASE_DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-...supabase.com:5432/postgres?sslmode=require

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM="Sun Container <tracking@updates.suncontainer.de>"
EMAIL_REPLY_TO=info@suncontainer.de
EMAIL_MODE=production          # log | sandbox | production
EMAIL_RECIPIENT_ALLOWLIST=     # optional: comma-separated allowlist for testing

# --- Rate limiting (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Captcha (Cloudflare Turnstile) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Monitoring (optional) ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- One-time admin profile creation (pnpm admin:create) ---
CREATE_ADMIN_AUTH_USER_ID=     # UUID of the Supabase Auth user
CREATE_ADMIN_EMAIL=
CREATE_ADMIN_FIRST_NAME=
CREATE_ADMIN_LAST_NAME=
CREATE_ADMIN_ROLE=SUPER_ADMIN
